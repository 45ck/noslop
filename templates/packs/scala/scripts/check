#!/bin/sh
# noslop check script for Scala
TIER="${NOSLOP_TIER:-${1:-fast}}"

case "$TIER" in
  fast)
    sbt scalafmtCheckAll && sbt "scalafix --check" && typos
    ;;
  slow)
    sbt compile && sbt test
    ;;
  ci)
    sbt scalafmtCheckAll "scalafix --check" && typos && sbt compile && sbt test
    ;;
  *)
    echo "Unknown tier: $TIER — use: fast, slow, or ci" >&2
    exit 1
    ;;
esac
