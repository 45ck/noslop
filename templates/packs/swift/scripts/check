#!/bin/sh
# noslop check script for Swift
TIER="${NOSLOP_TIER:-${1:-fast}}"

case "$TIER" in
  fast)
    swift-format lint --recursive . && swiftlint lint && typos
    ;;
  slow)
    swift build && swift test
    ;;
  ci)
    swift-format lint --recursive . && swiftlint lint && typos && swift build && swift test
    ;;
  *)
    echo "Unknown tier: $TIER — use: fast, slow, or ci" >&2
    exit 1
    ;;
esac
