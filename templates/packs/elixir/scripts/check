#!/bin/sh
# noslop check script for Elixir
TIER="${NOSLOP_TIER:-${1:-fast}}"

case "$TIER" in
  fast)
    mix format --check-formatted && mix credo --strict && typos
    ;;
  slow)
    mix dialyzer && mix test
    ;;
  ci)
    mix format --check-formatted && mix credo --strict && typos && mix dialyzer && mix test
    ;;
  *)
    echo "Unknown tier: $TIER — use: fast, slow, or ci" >&2
    exit 1
    ;;
esac
