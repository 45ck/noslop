#!/bin/sh
# noslop check script for Java
TIER="${NOSLOP_TIER:-${1:-fast}}"

case "$TIER" in
  fast)
    ./gradlew checkstyleMain checkstyleTest -q && ./gradlew pmdMain -q && typos
    ;;
  slow)
    ./gradlew build -x test && ./gradlew test
    ;;
  ci)
    ./gradlew checkstyleMain checkstyleTest -q && ./gradlew pmdMain -q && typos && ./gradlew build -x test && ./gradlew test
    ;;
  *)
    echo "Unknown tier: $TIER — use: fast, slow, or ci" >&2
    exit 1
    ;;
esac
