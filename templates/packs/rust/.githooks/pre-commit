#!/bin/sh
# noslop pre-commit: fast gates (format, lint, spell)
set -e

# Block commits that modify protected quality gate config files.
# Uses line-by-line comparison to avoid substring false positives.
PROTECTED_CONFIGS="clippy.toml rustfmt.toml"
while IFS= read -r staged_file; do
  for cfg in $PROTECTED_CONFIGS; do
    if [ "$staged_file" = "$cfg" ]; then
      echo "noslop: $cfg is a protected quality gate config — changes cannot be committed." >&2
      exit 1
    fi
  done
done << STAGED
$(git diff --cached --name-only 2>/dev/null)
STAGED

if command -v npx >/dev/null 2>&1 && npx --no-install noslop --version >/dev/null 2>&1; then
  npx --no-install noslop check --tier=fast
elif command -v noslop >/dev/null 2>&1; then
  noslop check --tier=fast
else
  cargo fmt --check && cargo clippy -- -D warnings
fi
