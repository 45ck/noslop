#!/bin/sh
# noslop check script — delegates to npm scripts by tier
TIER="${NOSLOP_TIER:-${1:-fast}}"

case "$TIER" in
  fast)
    scripts/run-package-script format:check &&
      scripts/run-package-script lint &&
      scripts/run-package-script spell
    ;;
  slow)
    scripts/run-package-script typecheck &&
      scripts/run-package-script test
    ;;
  ci)
    scripts/run-package-script ci
    ;;
  *)
    echo "Unknown tier: $TIER — use: fast, slow, or ci" >&2
    exit 1
    ;;
esac
