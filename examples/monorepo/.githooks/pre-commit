#!/bin/sh
# noslop pre-commit: fast gates (fmt, check)
set -e

# Block commits that modify protected quality gate config files
PROTECTED_CONFIGS=".ocamlformat"
STAGED=$(git diff --cached --name-only 2>/dev/null)
for cfg in $PROTECTED_CONFIGS; do
  if echo "$STAGED" | grep -qF "$cfg"; then
    echo "noslop: $cfg is a protected quality gate config — changes cannot be committed." >&2
    exit 1
  fi
done


if command -v noslop >/dev/null 2>&1; then
  noslop check --tier=fast
else
  dune build @fmt @check
fi
