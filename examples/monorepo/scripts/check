#!/bin/sh
# noslop check script for OCaml
TIER="${NOSLOP_TIER:-${1:-fast}}"

case "$TIER" in
  fast)
    dune build @fmt && dune build @check && typos
    ;;
  slow)
    dune build && dune runtest
    ;;
  ci)
    dune build @fmt @check && typos && dune build && dune runtest
    ;;
  *)
    echo "Unknown tier: $TIER — use: fast, slow, or ci" >&2
    exit 1
    ;;
esac
